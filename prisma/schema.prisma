generator client {
  provider = "prisma-client-js"
}

// Notice that the new Prisma 6 standard uses Prisma configs or standard URLs.
// We will point it to a local SQLite file.
datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id             String    @id @default(cuid())
  username       String    @unique
  password       String
  email          String?   // for email notifications
  role           String    @default("employee") // "super_admin" | "admin" | "employee"
  employeeCode   String?
  createdAt      DateTime  @default(now())
}

model Employee {
  id              String   @id @default(cuid())
  code            String   @unique
  name            String
  birthday        DateTime?
  workAnniversary DateTime?
  records         MonthRecord[]
  dailyLogs       DailyLog[]
  overrides       Override[]
  leaveBalances   LeaveBalance[]
  leaveRequests   LeaveRequest[]
  regularizations RegularizationRequest[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model PendingChange {
  id           String   @id @default(cuid())
  requestedBy  String   // username of admin who made the change
  action       String   // "toggleOverride" | "clearOverrides" | "uploadMonth" | "deleteMonth"
  payload      String   // JSON stringified payload
  status       String   @default("pending") // "pending" | "approved" | "rejected"
  reviewedBy   String?  // super_admin username who reviewed
  reviewedAt   DateTime?
  createdAt    DateTime @default(now())
}

model MonthRecord {
  id         String   @id @default(cuid())
  monthYear  String   // e.g "3_2026"
  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  
  present    Int      @default(0)
  absent     Int      @default(0)
  halfDay    Int      @default(0)
  late       Int      @default(0)
  lateHD     Int      @default(0)
  shortShift Int      @default(0)
  ssHD       Int      @default(0)
  shortLeave Int      @default(0)
  rl         Int      @default(0)
  holi       Int      @default(0)
  
  numDays    Int      @default(31)

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([employeeId, monthYear])
}

model DailyLog {
  id         String   @id @default(cuid())
  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  
  monthYear  String   // e.g. "3_2026"
  day        Int      // 1 to 31
  
  type       String   // "present", "absent", "half", "holiday", "wo", "rl"
  raw        String   @default("")
  
  inT        Int?
  outT       Int?
  
  isLate     Boolean  @default(false)
  isSS       Boolean  @default(false)
  isSL       Boolean  @default(false)

  @@unique([employeeId, monthYear, day])
}

model Override {
  id         String   @id @default(cuid())
  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  
  monthYear  String
  day        Int
  
  type       String   // "wfm", "wfm-hd", "wfh", "wos", "wos-hd"

  @@unique([employeeId, monthYear, day])
}

// Leave quota policy — one per year (global, applies to all employees)
model LeavePolicy {
  id        String @id @default(cuid())
  year      Int    @unique
  cl        Int    @default(12)  // Casual Leave
  sl        Int    @default(6)   // Sick Leave
  el        Int    @default(15)  // Earned Leave
  rl        Int    @default(2)   // Restricted Leave
  createdAt DateTime @default(now())
}

// Per-employee leave balance for a given year
model LeaveBalance {
  id           String   @id @default(cuid())
  employeeId   String
  employee     Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  year         Int
  clTotal      Int      @default(12)
  slTotal      Int      @default(6)
  elTotal      Int      @default(15)
  rlTotal      Int      @default(2)
  clUsed       Int      @default(0)
  slUsed       Int      @default(0)
  elUsed       Int      @default(0)
  rlUsed       Int      @default(0)
  clCarry      Int      @default(0)  // carried forward from previous year
  updatedAt    DateTime @updatedAt
  createdAt    DateTime @default(now())

  @@unique([employeeId, year])
}

// Leave requests submitted by employees
model LeaveRequest {
  id           String   @id @default(cuid())
  employeeId   String
  employee     Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  leaveType    String   // "cl" | "sl" | "el" | "rl"
  fromDate     DateTime
  toDate       DateTime
  days         Float    // 0.5 for half day, 1+ for full days
  reason       String
  status       String   @default("pending") // "pending" | "approved" | "rejected"
  reviewedBy   String?
  reviewedAt   DateTime?
  reviewNote   String?
  createdAt    DateTime @default(now())
}

// Regularization requests — employee requests correction for missed punch
model RegularizationRequest {
  id           String   @id @default(cuid())
  employeeId   String
  employee     Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  date         DateTime
  requestedIn  String?  // HH:MM
  requestedOut String?  // HH:MM
  reason       String
  status       String   @default("pending") // "pending" | "approved" | "rejected"
  reviewedBy   String?
  reviewedAt   DateTime?
  createdAt    DateTime @default(now())
}

// Phase 10 — Company holiday calendar
model Holiday {
  id        String   @id @default(cuid())
  year      Int
  month     Int
  day       Int
  name      String
  type      String   @default("national") // "national" | "optional"
  createdAt DateTime @default(now())

  @@unique([year, month, day])
}

// Phase 11 — Shift & HR policy configuration
model ShiftPolicy {
  id              String   @id @default(cuid())
  name            String   @default("Default")
  shiftStartH     Int      @default(10)  // 10:00 AM
  shiftStartM     Int      @default(0)
  graceMinutes    Int      @default(15)  // late after 10:15
  minHours        Float    @default(9)   // minimum working hours
  latesPerHD      Int      @default(3)   // 3 lates = 1 HD
  ssPerHD         Int      @default(3)   // 3 short shifts = 1 HD
  effectiveFrom   DateTime @default(now())
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
}

// Phase 12 — Audit log
model AuditLog {
  id          String   @id @default(cuid())
  performedBy String   // username
  action      String   // e.g. "override_applied", "leave_approved", "user_created"
  entity      String   // e.g. "employee", "leave_request", "user"
  entityId    String?  // id of the affected record
  detail      String   // human-readable description
  createdAt   DateTime @default(now())
}
